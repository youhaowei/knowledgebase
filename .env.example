# Knowledgebase environment variables
# All variables are optional — defaults shown make the project work out of the box.

# --- Filesystem (Spec Decision #1, #11) ---
# KB_MEMORY_PATH=~/.kb/memories          # Memory directory root
# LADYBUG_DATA_PATH=./.ladybug           # LadybugDB data dir (graph index)

# --- Embedding (Spec Decision: built-in 384-dim is primary) ---
# EMBEDDING_MODEL=built-in               # Or "ollama" for opt-in 2560-dim
# OLLAMA_URL=http://localhost:11434      # Used when EMBEDDING_MODEL=ollama

# --- Extraction ---
# EXTRACTION_MODEL=gemma4:e4b            # Ollama model for entity/edge extraction
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-... # Optional: enables unifai/Haiku extraction

# --- Optional Neo4j backend (replaces LadybugDB when set) ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# --- Server / indexer ---
# KB_DISABLE_SERVER_INDEXER=true         # Skip the 60s reconciliation sweep
